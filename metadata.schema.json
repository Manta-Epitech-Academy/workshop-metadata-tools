{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kevin-cazal/workshop-metadata-tools/main/metadata.schema.json",
  "title": "Workshop metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "runtime", "toc"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$|^\\d+\\.\\d+$",
      "description": "Semantic version of this metadata document shape."
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "slug", "summary", "entrypoint"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "description": "Primary document (e.g. landing page). Additional files are listed under toc."
        }
      }
    },
    "authors": {
      "type": "array",
      "items": { "$ref": "#/$defs/Author" }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "language"],
      "properties": {
        "engine": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 }
      }
    },
    "documents": {
      "type": "array",
      "description": "Declared markdown files in this repo and optional reading order constraints.",
      "items": { "$ref": "#/$defs/Document" }
    },
    "toc": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TocDocument" },
          "description": "One or more markdown files, each with its own section tree."
        },
        {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TocNode" },
          "description": "Legacy: flat section tree for a single file named by project.entrypoint."
        }
      ]
    },
    "observables": {
      "type": "array",
      "description": "Grading observables for this project. Each entry maps to one measurable learner action.",
      "items": { "$ref": "#/$defs/Observable" }
    }
  },
  "$defs": {
    "Document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\.md$",
          "description": "Path to a markdown file relative to metadata.yaml (POSIX slashes)."
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\.md$"
          },
          "uniqueItems": true,
          "description": "Other markdown files that should be read before this one (prerequisites)."
        }
      }
    },
    "Author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" }
      }
    },
    "TocDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "sections"],
      "properties": {
        "document": {
          "type": "string",
          "minLength": 1,
          "description": "Path to the markdown file relative to metadata.yaml (POSIX slashes)."
        },
        "sections": {
          "type": "array",
          "description": "Heading tree for that file (H1 roots, nested parts).",
          "items": { "$ref": "#/$defs/TocNode" }
        }
      }
    },
    "TocNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "competency": {
          "type": "array",
          "items": { "$ref": "#/$defs/CompetencyRef" },
          "description": "Structured competency / grading hooks for this section (resolve path + optional workshop observable id)."
        },
        "parts": {
          "type": "array",
          "items": { "$ref": "#/$defs/TocNode" }
        }
      }
    },
    "CompetencyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "skill", "level", "project", "obs_index"],
      "properties": {
        "domain": {
          "type": "string",
          "pattern": "^[A-Z]+$",
          "description": "Competency domain (e.g. PROG, TRANS)."
        },
        "skill": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Skill number as digits (e.g. 01 or 1)."
        },
        "level": {
          "type": "string",
          "pattern": "^[A-Z][0-9]+$",
          "description": "Level code such as A1, A2."
        },
        "project": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Workshop project slug; must match `project.slug` in this file."
        },
        "obs_index": {
          "type": "integer",
          "minimum": 1,
          "description": "For framework domains (e.g. PROG): 1-based index in GET /api/v1/resolve/.../{obs_num}. For workshop-only domains (e.g. TRANS) without API mapping, use the workshop ordinal from your grading model."
        },
        "observable_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*\\.\\d+$",
          "description": "When `observables` is declared, each hook must list its id (typically `{project.slug}.N`). Required in that case (enforced by check_toc.py)."
        }
      }
    },
    "Observable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "observation"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*\\.\\d+$",
          "description": "Unique observable identifier: {project-slug}.{number} (e.g. your-workshop.1)"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Short label for the observable."
        },
        "observation": {
          "type": "string",
          "minLength": 1,
          "description": "What the assessor looks for in the learner's work."
        }
      }
    }
  }
}
